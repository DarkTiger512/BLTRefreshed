PORT=8088

# Twitch Extension identity
EXT_CLIENT_ID=
EXT_SECRET=

# Helix app credentials (for Extensions PubSub)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=


# Shared secret used to authenticate mod <-> EBS websocket connections
# Keep this value secret in production. Example: a long random string
MOD_SHARED_SECRET=

# Allowed origin for CORS; use '*' for dev/testing
MOD_ALLOWED_ORIGIN=*

